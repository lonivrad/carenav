# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit real keys; the empty template stays tracked
.env*
!.env.example

# vercel
.vercel

# playwright (a11y e2e) — reports and browser cache are never committed
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# typescript
*.tsbuildinfo
next-env.d.ts

# logs
*.log

# process id / runtime files
*.pid
*.pid.lock
.pids/

# OS / editor
Thumbs.db
.idea/
*.swp
*.swo

# local eval scratch (committed eval artifacts live in eval/results/)
/tmp/

# local tooling configuration (never commit)
CLAUDE.md
.claude/
